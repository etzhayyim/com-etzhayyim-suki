  "constitutionalGates": {
    "description": "14 immutable gates per ADR-2605261500. Changes require Council Lv6+ supermajority + new ADR.",
    "gates": {
      "G1": "All hardware open-source — chassis CAD (FreeCAD .fcstd) + 3-point hitch + PTO spec + hydraulic schematic public Apache 2.0 + Charter Rider",
      "G2": "All firmware open-source — ECU + hydraulic control + dash UI (no John Deere proprietary CAN); bootloader unlock = default state",
      "G3": "Modular implement attachment — Category I/II/III 3-point hitch + standard PTO 540/1000 RPM (ISO 730 + ISO 500); no parts pairing",
      "G4": "Witness quorum ≥2 robot signers (Mimi precision + Otete handling) per vehicleManufactureRecord Ed25519",
      "G5": "Bilingual (JA + EN) operator manual + repair manual + ag-machine operator certification reference + ag-mechanic training curriculum public",
      "G6": "§2(a) clearance — no military tractor / no riot-control / no surveillance modifications",
      "G7": "Fuel transition phase gate: R0/R1 B100 biodiesel + diesel hybrid; R2+ LFP / H₂ / methanol fuel-cell only — pure-fossil phased out at R2 (sarutahiko G7 parallel)",
      "G8": "Emissions EU Stage V + EPA Tier 4 Final + 日本特殊自動車排ガス R0-R1 tailpipe; R2+ zero tailpipe",
      "G9": "§2(b) anti-IP locking — open ECU + open CAN bus + open hydraulic control + open implement-detection (no DRM signature gate); ECU re-flash via openly published JTAG/UART",
      "G10": "Right-to-Repair constitutional invariant — no software lockouts requiring dealer authorization; replacement parts catalogued openly; ECU re-flash on parts swap NOT manufacturer-gated; diagnostic codes interpretable from open docs. **Religious-corp first explicit RTR constitutional first-class invariant at firmware level (tsutae G3 hardware + suki G10 firmware = dual-layer R2R)**",
      "G11": "Personnel vetting — Adherent SBT + 大型特殊自動車免許 (JP) / ag-machine operator certification + ag-mechanic SME registration",
      "G12": "KPI cap — Wave 1 ≤200 hp / road ≤40 km/h / field ≤15 km/h / autonomous ≤ SAE J3016 Level 3 (Level 5 = N6 NEVER) / max axle load ≤8 t",
      "G13": "Murakumo mesh placement + LANDS.md land-trust integration + 30-day prior notice + 1 km community feedback",
      "G14": "Every tractor = open VIN + per-vehicle DID did:web:etzhayyim.com:suki:vehicle:<vin> + IPFS-pinned BoM + repair-history-ready blockchain record + EOL recyclability ≥85% by mass (kanayama Wave 1 Al + Wave 2 steel + Wave 3 Cu)"
    }
  },
